if not isfolder("xvchub") then makefolder("xvchub") end

path = "xvchub/mp3/blstudioloop.mp3"

if not isfile(path) then
    writefile(path, game:HttpGet("https://github.com/XVCHub/Musics/raw/main/musics/sources/blstudioloop.mp3"))
end

_ = Instance.new("Sound", game:GetService("SoundService"))
_.SoundId = getcustomasset(path)
_.Volume = getgenv().volume or 1
_.Looped = getgenv().loop == true
_:Play()

if not _.Looped then
    _.Ended:Connect(function()
        _:Destroy()
    end)
end
